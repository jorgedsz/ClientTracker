{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"],
      "phases": {
        "setup": {
          "nixPkgs": ["chromium", "nss", "freetype", "harfbuzz", "ca-certificates", "fontconfig"]
        },
        "install": {
          "cmds": [
            "cd server && npm install",
            "cd client && npm install"
          ]
        },
        "build": {
          "cmds": [
            "cd server && npx prisma generate",
            "cd client && npm run build"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd server && npx prisma migrate deploy && node src/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
